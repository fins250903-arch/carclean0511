---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import '../../styles/blog.css';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => {
		const slug = post.id.replace(/\/index$/, '');
		return {
			params: { slug },
			props: post,
		};
	});
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const postSlug = post.id.replace(/\/index$/, '');
const heroImage = post.data.coverImage ? `/posts/${postSlug}/images/${post.data.coverImage}` : null;
const { Content } = await render(post);
---

<MainLayout
	title={`${post.data.title} | 車内清掃「特急便」`}
	description={post.data.description || post.data.title}
>
	<main class="blog-content min-h-screen bg-white pb-32 md:pb-12">
		<article>
			<!-- ヒーロー画像 -->
			{heroImage && (
				<div class="w-full max-h-[500px] overflow-hidden">
					<img src={heroImage} alt={post.data.title} class="w-full h-full object-cover" />
				</div>
			)}

			<!-- 記事本文 -->
			<div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
				<!-- タイトルエリア -->
				<div class="mb-8 pb-6 border-b border-gray-200">
					<p class="text-gray-500 mb-3">
						<FormattedDate date={post.data.date} />
						{post.data.updatedDate && (
							<span class="ml-2 text-sm italic">
								(更新: <FormattedDate date={post.data.updatedDate} />)
							</span>
						)}
					</p>
					<h1 class="text-2xl md:text-3xl font-bold text-gray-900 leading-tight">{post.data.title}</h1>
					{post.data.categories && (
						<div class="mt-4 flex flex-wrap gap-2">
							{post.data.categories.map((cat: string) => (
								<span class="text-xs bg-blue-50 text-blue-700 px-3 py-1 rounded-full font-medium">{cat}</span>
							))}
						</div>
					)}
				</div>

				<!-- 本文 -->
				<div class="prose max-w-none">
					<Content />
				</div>

				<!-- お問い合わせCTA -->
				<div class="mt-16 bg-blue-50 rounded-2xl p-8 border border-blue-100 text-center shadow-sm">
					<h3 class="text-2xl font-bold text-gray-900 mb-4">お車のお悩み、すぐ解決します！</h3>
					<p class="text-gray-700 mb-8">嘔吐、ペットの粗相、灯油こぼしなど、放置すると悪化するトラブルに最短即日で出張対応いたします。</p>
					
					<div class="flex flex-col sm:flex-row justify-center gap-4 mb-6">
						<a
							href="https://lin.ee/Xs8Orp2"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#06C755] hover:bg-[#05a346] !text-white font-bold py-4 px-8 rounded-full shadow-lg text-lg transition-transform hover:scale-105 flex items-center justify-center gap-2"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-message-circle"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
							LINEで無料見積もり
						</a>
						<a
							href="tel:07084280866"
							class="bg-red-600 hover:bg-red-700 !text-white font-bold py-4 px-8 rounded-full shadow-lg text-lg transition-transform hover:scale-105 flex items-center justify-center gap-2"
						>
							📞 070-8428-0866 に電話する
						</a>
					</div>
					<p class="text-sm text-gray-500">※お急ぎの場合はお電話が確実です。</p>
				</div>

				<!-- ナビゲーション -->
				<div class="mt-12 pt-6 border-t border-gray-200 flex flex-col sm:flex-row justify-center gap-6">
					<a href="http://carinteriorcleaning.jp/blog/" class="text-blue-600 hover:text-blue-800 font-bold transition-colors flex items-center justify-center bg-gray-50 px-6 py-3 rounded-full hover:bg-gray-100">
						← ブログ一覧へ戻る
					</a>
					<a href="http://carinteriorcleaning.jp/" class="text-blue-600 hover:text-blue-800 font-bold transition-colors flex items-center justify-center bg-gray-50 px-6 py-3 rounded-full hover:bg-gray-100">
						🏠 特急便トップページへ
					</a>
				</div>
			</div>
		</article>
	</main>
</MainLayout>
