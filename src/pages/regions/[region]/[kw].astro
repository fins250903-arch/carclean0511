---
import MainLayout from '../../../layouts/MainLayout.astro';
import { regions } from '../../../data/regions';
import {
  AD_KEYWORD_PAGES,
  getAdKeywordPage,
} from '../../../data/adKeywordPages';
import {
  generateAdKeywordRegionMetadata,
  generateJsonLd,
} from '../../../lib/seo';
import { getRegionalPost } from '../../../lib/getRegionalPost';
import { getRegionalBlogDisplayPosts } from '../../../lib/getRegionalBlogDisplayPosts';
import { buildRegionSeoOverrides } from '../../../lib/regionStructuredData';
import { buildAdKeywordJsonLdOptions } from '../../../lib/keywordSchemaOptions';
import { generateQuestionnaireJsonLd } from '../../../data/questionnaireTestimonials';
import JsonLd from '../../../components/seo/JsonLd.astro';

import Hero from '../../../components/sections/Hero.astro';
import AIOContent from '../../../components/sections/AIOContent.astro';
import RegionAIContent from '../../../components/sections/RegionAIContent.astro';
import Problem from '../../../components/sections/Problem.astro';
import Solution from '../../../components/sections/Solution.astro';
import Comparison from '../../../components/sections/Comparison.astro';
import Campaign from '../../../components/sections/Campaign.astro';
import CTA from '../../../components/sections/CTA.astro';
import FAQ from '../../../components/sections/FAQ.astro';
import Reasons from '../../../components/sections/Reasons.astro';
import Benefits from '../../../components/sections/Benefits.astro';
import Roadmap from '../../../components/sections/Roadmap.astro';
import RegionalAchievements from '../../../components/sections/RegionalAchievements.astro';
import Targets from '../../../components/sections/Targets.astro';
import AreaCoverage from '../../../components/sections/AreaCoverage.astro';
import Flow from '../../../components/sections/Flow.astro';
import Profile from '../../../components/sections/Profile.astro';
import Expertise from '../../../components/sections/Expertise.astro';
import Pricing from '../../../components/sections/Pricing.astro';
import OperatorInfo from '../../../components/sections/OperatorInfo.astro';
import Closing from '../../../components/sections/Closing.astro';
import ServiceMutualLink from '../../../components/sections/ServiceMutualLink.astro';
import TroubleSympathy from '../../../components/sections/TroubleSympathy.astro';
import KeywordMutualLinks from '../../../components/sections/KeywordMutualLinks.astro';
import EmergencyChecklist from '../../../components/sections/EmergencyChecklist.astro';
import AnswerTarget from '../../../components/sections/AnswerTarget.astro';
import NicheCaseStudy from '../../../components/sections/NicheCaseStudy.astro';
import { getAioKeywordContent } from '../../../data/aioKeywordContent';

import { RegionProvider } from '../../../lib/RegionContext';
import QuestionnaireTestimonials from '../../../components/sections/QuestionnaireTestimonials';
import Testimonials from '../../../components/sections/Testimonials';
import Blog from '../../../components/sections/Blog';
import ContactForm from '../../../components/sections/ContactForm';
import FloatingCTA from '../../../components/sections/FloatingCTA';

export async function getStaticPaths() {
  const paths: {
    params: { region: string; kw: string };
    props: { regionName: string; regionId: string };
  }[] = [];
  for (const region of regions) {
    for (const page of AD_KEYWORD_PAGES) {
      if (page.targetRegionIds && !page.targetRegionIds.includes(region.id)) {
        continue;
      }
      paths.push({
        params: { region: region.id, kw: page.slug },
        props: { regionName: region.name, regionId: region.id },
      });
    }
  }
  return paths;
}

const { regionName, regionId } = Astro.props;
const kwSlug = Astro.params.kw!;
const kw = getAdKeywordPage(kwSlug);
if (!kw) {
  throw new Error(`Unknown ad keyword slug: ${kwSlug}`);
}

const path = `/regions/${regionId}/${kwSlug}`;
const regionBasePath = `/regions/${regionId}`;

const post = getRegionalPost(regionName);
const displayName = post?.displayName || regionName;
const blogCases = getRegionalBlogDisplayPosts(regionId, regionName);
const questionnaireStructuredData = generateQuestionnaireJsonLd(
  regionName,
  displayName,
  path,
);
const regionOverrides = buildRegionSeoOverrides({
  regionName,
  displayName,
  blogCases,
});

const metadata = generateAdKeywordRegionMetadata(regionName, path, kw);
const aioKw = getAioKeywordContent(kwSlug);
const answerFirst = aioKw?.answerFirst(regionName, displayName);
const customDefinition = aioKw?.customDefinition?.(regionName);
const jsonLdData = generateJsonLd(
  regionName,
  path,
  regionOverrides,
  'car',
  {
    ...buildAdKeywordJsonLdOptions({
      kwSlug,
      kw,
      regionName,
      displayName,
      metadata,
    }),
    extraFaqs: aioKw?.extraFaqs,
  },
);
const combinedJsonLd = [...jsonLdData, ...questionnaireStructuredData];

const adHero = {
  subtitle: kw.heroSubtitle(displayName),
  highlightLine1: kw.heroHighlight[0],
  highlightLine2: kw.heroHighlight[1],
  subcatch: kw.heroSubcatch(displayName),
  fvImage: kw.fvImage,
  footerText: kw.heroFooter(displayName),
  mainTitle: kw.mainTitle?.(regionName, displayName),
};

const adProblem = {
  header: kw.problemHeader,
  subHeader: kw.problemSubHeader,
  dealerQuote: kw.problemDealerQuote,
  bodyHtml: kw.problemBodyHtml(regionName, displayName),
  empathyImage: kw.problemEmpathyImage,
  empathyAlt: kw.problemEmpathyAlt ?? '',
};

/** slug から niche を解決 */
const pageNiche: 'car' | 'truck' | 'bus' = kwSlug === 'bus-senmon' ? 'bus' : 'car';
---

<MainLayout
  title={metadata.title}
  description={metadata.description}
  keywords={metadata.keywords}
  canonical={metadata.alternates?.canonical}
  ogImage={kw.ogImage}
>
  <JsonLd slot="head" data={combinedJsonLd} />

  <RegionProvider client:load regionName={regionName} displayName={displayName} niche={pageNiche} path={path}>
    <main class="min-h-screen bg-white pb-floating md:pb-20">
      <Hero regionName={regionName} displayName={displayName} niche={pageNiche} adHero={adHero} />
      {answerFirst && <AnswerTarget text={answerFirst} />}
      <TroubleSympathy displayName={displayName} deepTroubles={kw.deepTroubles} />
      {aioKw?.emergencyChecklist && (
        <EmergencyChecklist rows={aioKw.emergencyChecklist} regionName={regionName} />
      )}
      <AIOContent
        regionName={regionName}
        niche={pageNiche}
        focusShutchou={kwSlug === 'shutchou-senmon'}
        customDefinition={customDefinition}
        extraFaqs={aioKw?.extraFaqs}
      />
      {aioKw?.nicheCaseStudy && (
        <NicheCaseStudy block={aioKw.nicheCaseStudy(regionName)} />
      )}
      <RegionAIContent regionName={regionName} displayName={displayName} />
      <Problem regionName={regionName} displayName={displayName} niche={pageNiche} adProblem={adProblem} />
      <Solution regionName={regionName} displayName={displayName} niche={pageNiche} />
      <Comparison displayName={displayName} />

      <Campaign displayName={displayName} />
      <Reasons displayName={displayName} regionName={regionName} />
      <Benefits />
      <Roadmap displayName={displayName} />

      <QuestionnaireTestimonials client:visible displayName={displayName} />
      <RegionalAchievements
        regionName={regionName}
        displayName={displayName}
        niche={pageNiche}
        troubleType={aioKw?.troubleType}
      />
      <Targets />
      <AreaCoverage regionName={regionName} />
      <Flow niche={pageNiche} />
      <Profile displayName={displayName} />
      <Expertise />
      <Pricing regionName={regionName} niche={pageNiche} />
      <CTA />
      <FAQ niche={pageNiche} extraFaqs={aioKw?.extraFaqs} />
      <Blog client:visible regionName={regionName} displayName={displayName} />
      <ServiceMutualLink
        regionName={regionName}
        displayName={displayName}
        niche={pageNiche}
        path={path}
        regionBasePath={regionBasePath}
      />
      <KeywordMutualLinks regionId={regionId} regionName={regionName} currentSlug={kwSlug} />
      <ContactForm client:visible regionName={regionName} />
      <OperatorInfo regionName={regionName} displayName={displayName} />
      <Closing regionName={regionName} displayName={displayName} niche={pageNiche} path={path} />
      <FloatingCTA client:load />
    </main>
  </RegionProvider>
</MainLayout>
