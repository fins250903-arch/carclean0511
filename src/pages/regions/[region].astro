---
import MainLayout from '../../layouts/MainLayout.astro';
import { regions } from '../../data/regions';
import { getRegionCustomization } from '../../data/regionCustomization';
import { generateRegionMetadata, generateJsonLd } from '../../lib/seo';
import type { ServiceNiche } from '../../lib/niche';
import { regionPath } from '../../lib/niche';
import { getRegionalPost } from '../../lib/getRegionalPost';
import { getRegionalBlogDisplayPosts } from '../../lib/getRegionalBlogDisplayPosts';
import { buildRegionSeoOverrides } from '../../lib/regionStructuredData';
import { generateQuestionnaireJsonLd } from '../../data/questionnaireTestimonials';
import JsonLd from '../../components/seo/JsonLd.astro';

// Astro Components
import Hero from '../../components/sections/Hero.astro';
import AIOContent from '../../components/sections/AIOContent.astro';
import RegionAIContent from '../../components/sections/RegionAIContent.astro';
import Problem from '../../components/sections/Problem.astro';
import Solution from '../../components/sections/Solution.astro';
import Comparison from '../../components/sections/Comparison.astro';
import Campaign from '../../components/sections/Campaign.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import Reasons from '../../components/sections/Reasons.astro';
import Benefits from '../../components/sections/Benefits.astro';
import Roadmap from '../../components/sections/Roadmap.astro';
import RegionalAchievements from '../../components/sections/RegionalAchievements.astro';
import Targets from '../../components/sections/Targets.astro';
import AreaCoverage from '../../components/sections/AreaCoverage.astro';
import Flow from '../../components/sections/Flow.astro';
import Profile from '../../components/sections/Profile.astro';
import Expertise from '../../components/sections/Expertise.astro';
import Pricing from '../../components/sections/Pricing.astro';
import OperatorInfo from '../../components/sections/OperatorInfo.astro';
import Closing from '../../components/sections/Closing.astro';
import ServiceMutualLink from '../../components/sections/ServiceMutualLink.astro';
import EmergencyChecklist from '../../components/sections/EmergencyChecklist.astro';
import AnswerTarget from '../../components/sections/AnswerTarget.astro';
import NioiAnswerTarget from '../../components/sections/NioiAnswerTarget.astro';
import {
  buildRegionalAnswerFirst,
  buildRegionalNioiAnswerFirst,
  getRegionalHeroMainTitle,
  REGIONAL_EMERGENCY_CHECKLIST,
  buildAioContentFaqs,
} from '../../data/aioKeywordContent';
import RegionLocalTrust from '../../components/sections/RegionLocalTrust.astro';

// React Components
import { RegionProvider } from '../../lib/RegionContext';
import QuestionnaireTestimonials from '../../components/sections/QuestionnaireTestimonials';
import Testimonials from '../../components/sections/Testimonials';
import Blog from '../../components/sections/Blog';
import ContactForm from '../../components/sections/ContactForm';
import FloatingCTA from '../../components/sections/FloatingCTA';

export async function getStaticPaths() {
  const paths = [];
  regions.forEach(region => {
    // Standard page
    paths.push({
      params: { region: region.id },
      props: { regionName: region.name, niche: 'car' as ServiceNiche, path: regionPath(region.id, 'car') }
    });
    // Truck page
    paths.push({
      params: { region: `${region.id}-truck` },
      props: { regionName: region.name, niche: 'truck' as ServiceNiche, path: regionPath(region.id, 'truck') }
    });
    // Bus page（出張車内清掃・バス専門）
    paths.push({
      params: { region: `${region.id}-bus` },
      props: { regionName: region.name, niche: 'bus' as ServiceNiche, path: regionPath(region.id, 'bus') }
    });
  });
  return paths;
}

const { regionName, niche, path } = Astro.props as {
  regionName: string;
  niche: ServiceNiche;
  path: string;
};
const isTruck = niche === 'truck';
const isBus = niche === 'bus';

const regionId = Astro.params.region?.replace(/-truck$/, '').replace(/-bus$/, '');
const post = getRegionalPost(regionName);
const regionCustom = getRegionCustomization(regionName);
const displayName = post?.displayName || regionName;
const blogCases = getRegionalBlogDisplayPosts(regionId, regionName);
const questionnaireStructuredData = generateQuestionnaireJsonLd(regionName, displayName, path);
const regionOverrides = buildRegionSeoOverrides({
    regionName,
    displayName,
    blogCases,
    aiSummary: regionCustom.aioSummaryExtra
      ? `${post?.aiSummary ?? ''} ${regionCustom.aioSummaryExtra}`.trim()
      : undefined,
});

const metadata = generateRegionMetadata(regionName, path, niche);
const jsonLdData = generateJsonLd(regionName, path, regionOverrides, niche, {
  extraFaqs: !isTruck && !isBus ? buildAioContentFaqs(regionName) : [],
});
const combinedJsonLd = [...jsonLdData, ...questionnaireStructuredData];
const regionalAnswerFirst = !isTruck && !isBus ? buildRegionalAnswerFirst(regionName) : undefined;
const regionalNioiAnswer = !isTruck && !isBus ? buildRegionalNioiAnswerFirst(regionName) : undefined;
const heroMainTitle = !isTruck && !isBus ? getRegionalHeroMainTitle(regionName) : undefined;

---

<MainLayout 
  title={metadata.title}
  description={metadata.description}
  keywords={metadata.keywords}
  canonical={metadata.alternates.canonical}
  ogImage={isTruck ? '/images/truck-fv.png' : isBus ? '/images/kw/bus-fv.png' : '/images/fv-passenger-hero.png'}
>
  <JsonLd slot="head" data={combinedJsonLd} />

  <RegionProvider client:load regionName={regionName} displayName={displayName} niche={niche} path={path}>
    <main class="min-h-screen bg-white pb-floating md:pb-20">
      <Hero regionName={regionName} displayName={displayName} niche={niche} mainTitle={heroMainTitle} />
      {regionalAnswerFirst && <AnswerTarget text={regionalAnswerFirst} />}
      <RegionLocalTrust regionName={regionName} displayName={displayName} niche={niche} />
      {!isTruck && !isBus && (
        <EmergencyChecklist rows={REGIONAL_EMERGENCY_CHECKLIST} regionName={regionName} />
      )}
      {regionalNioiAnswer && (
        <NioiAnswerTarget regionName={regionName} answerText={regionalNioiAnswer} />
      )}
      <AIOContent
        regionName={regionName}
        niche={niche}
        focusShutchou
        showAioExtensions={!isTruck}
      />
      <RegionAIContent regionName={regionName} displayName={displayName} />
      <Problem regionName={regionName} displayName={displayName} niche={niche} />
      <Solution regionName={regionName} displayName={displayName} niche={niche} />
      <Comparison displayName={displayName} />
      
      <Campaign displayName={displayName} />
      <Reasons displayName={displayName} regionName={regionName} />
      <Benefits />
      <Roadmap displayName={displayName} />
      
      <QuestionnaireTestimonials client:visible displayName={displayName} />
      <RegionalAchievements regionName={regionName} displayName={displayName} niche={niche} />
      <Targets />
      <AreaCoverage regionName={regionName} />
      <Flow niche={niche} />
      <Profile displayName={displayName} />
      <Expertise />
      <Pricing regionName={regionName} niche={niche} />
      <CTA />
      <FAQ niche={niche} />
      <Blog client:visible regionName={regionName} displayName={displayName} />
      <ServiceMutualLink regionName={regionName} displayName={displayName} niche={niche} path={path} />
      <ContactForm client:visible regionName={regionName} />
      <OperatorInfo regionName={regionName} displayName={displayName} />
      <Closing regionName={regionName} displayName={displayName} niche={niche} path={path} />
      <FloatingCTA client:load />
    </main>
  </RegionProvider>
</MainLayout>


