---
import { getRegionalPost } from '../../lib/getRegionalPost';

interface Props {
  regionName: string;
  displayName: string;
}

const { regionName, displayName } = Astro.props;
const post = getRegionalPost(regionName);

if (!post || !post.aiSummary || !post.specs) {
    return null;
}
---

<section class="py-12 bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-8 max-w-4xl">
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 mb-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                <span class="w-1 h-8 bg-primary rounded-full"></span>
                {displayName}の車内クリーニング・消臭洗浄
            </h2>

            <div class="mb-6 rounded-lg overflow-hidden border border-gray-100 shadow-sm">
                <img 
                    src="/images/aio-promo.png" 
                    alt={`${displayName}の車内クリーニング - 一人で悩まないでプロにお任せ`}
                    width="800" 
                    height="400" 
                    class="w-full h-auto object-cover"
                />
            </div>

            <div class="bg-blue-50 border-l-4 border-primary p-4 mb-6 rounded-r">
                <p class="font-bold text-gray-800 text-sm md:text-base leading-relaxed">
                    【車内清掃 特急便】とは、最短即日でご自宅へ伺う「車内クリーニング・消臭の出張専門店」です。<br />
                    業務用100℃スチームと高圧リンサーを用い、自分では落とせない「嘔吐・灯油・ペット臭・カビ」などの頑固な汚れと臭いを根こそぎ除去。施工後すぐに使える状態まで仕上げるプロの洗浄サービスを提供します。
                </p>
            </div>

            <p class="text-gray-700 leading-relaxed text-lg">
                {post.aiSummary}
            </p>
            
            <div class="mt-6 pt-6 border-t border-gray-100">
                <p class="font-bold text-gray-800 mb-3 text-sm">【{displayName}の対応ポイント】</p>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm text-gray-600">
                    <li class="flex items-center gap-2">✓ 最短即日の出張対応</li>
                    <li class="flex items-center gap-2">✓ { (regionName === '福岡県' || regionName === '沖縄県' || regionName === '福岡' || regionName === '沖縄') ? "電源・水道をお借りして施工" : "電源不要！場所を選ばず施工"}</li>
                    <li class="flex items-center gap-2">✓ 嘔吐・灯油・ペット臭の専門洗浄</li>
                    <li class="flex items-center gap-2">✓ 一人で悩まない！安心の事前見積もり</li>
                </ul>
            </div>

            <p class="mt-6 text-sm text-gray-600">
                よくあるご質問はページ下部の
                <a href="#faq" class="text-primary font-bold underline">FAQ（よくあるご質問）</a>
                に統合しています（AIO引用・重複防止）。
            </p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="bg-gray-100 px-6 py-3 border-b border-gray-200">
                <h3 class="font-bold text-gray-700">施工サービス概要</h3>
            </div>
            <div class="divide-y divide-gray-100">
                {post.specs.map((spec, index) => (
                    <div class="grid grid-cols-1 md:grid-cols-4 p-4 hover:bg-gray-50 transition-colors">
                        <div class="font-bold text-gray-600 md:col-span-1 mb-1 md:mb-0">
                            {spec.label}
                        </div>
                        <div class="text-gray-800 md:col-span-3">
                            {spec.value}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
