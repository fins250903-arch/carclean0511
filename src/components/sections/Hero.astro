---
import { STORE_NAME } from '../../lib/site';
import { IMG513 } from '../../lib/assets513';

interface AdHeroOverrides {
  subtitle: string;
  highlightLine1: string;
  highlightLine2: string;
  subcatch: string;
  fvImage: string;
  footerText: string;
}

interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck';
  adHero?: AdHeroOverrides;
}

const { regionName, displayName, niche = 'car', adHero } = Astro.props;
const isTruck = niche === 'truck';

const subtitle = adHero?.subtitle ?? (isTruck 
    ? `${displayName}トラックキャビン清掃専門店/キャビン洗浄`
    : `${displayName}車内クリーニング専門店/シート洗浄`);

const fvImage = adHero?.fvImage ?? (isTruck ? "/images/truck-fv.png" : IMG513.fvCar);

/** FVブロック間の余白（モバイルは詰めて最上部から表示） */
const gap = 'mb-1.5 max-md:mb-1 sm:mb-2 md:mb-3';
const gapTight = 'mb-1 max-md:mb-0.5 sm:mb-1.5';
---

<section class="relative w-full min-h-0 md:min-h-[95vh] flex items-start bg-white overflow-hidden max-md:pb-2 md:pb-0">
    <div class="absolute inset-0 w-full h-full z-0">
        <img
            src={fvImage}
            alt={`${displayName}対応 ${STORE_NAME}`}
            class="w-full h-full object-cover max-md:object-[center_35%] md:object-[center_bottom] md:object-right opacity-90"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 to-transparent z-10 max-md:from-white/70 max-md:via-white/50 max-md:to-transparent"></div>
    </div>

    <div class="container mx-auto px-3 sm:px-6 md:px-16 z-20 relative w-full max-md:pt-[max(0.25rem,env(safe-area-inset-top))] md:pt-8 max-md:pb-1">
        <div class="max-w-3xl">
            {/* ── 全LP共通 ── */}
            {/* 1. バッジ */}
            <div class:list={[gapTight, 'flex flex-wrap gap-1.5 sm:gap-2']}>
                <span class="inline-flex bg-red-600 text-white text-xs sm:text-sm md:text-base font-bold px-2 sm:px-4 py-0.5 sm:py-1.5 rounded-full">
                    ３６５日２４時間受付中
                </span>
                <span class="inline-flex bg-blue-900 text-white text-xs sm:text-sm md:text-base font-bold px-2 sm:px-4 py-0.5 sm:py-1.5 rounded-full">
                    "出張"車内クリーニング業者
                </span>
            </div>

            {/* 2. 小見出し（キーワードLPのみ：ご指定のキーワード） */}
            {adHero ? (
                <div class:list={[gap, 'space-y-0.5 sm:space-y-1']}>
                    <p class="text-lg sm:text-2xl md:text-4xl font-black text-blue-900 leading-tight tracking-tight drop-shadow-sm">
                        ご指定のキーワード
                    </p>
                    <p class="text-xl sm:text-3xl md:text-5xl font-black text-gray-900 leading-[1.12] tracking-tight border-b-[3px] sm:border-b-4 border-blue-600 inline-block pr-1 max-w-full">
                        {subtitle}
                    </p>
                </div>
            ) : (
                <p class:list={[gap, 'text-sm sm:text-base md:text-2xl font-bold text-gray-800 leading-snug']}>
                    {subtitle}
                </p>
            )}

            {/* 3. キーワードLPのみ：特典リボン */}
            {adHero && (
                <div class:list={[gap, 'flex flex-wrap items-baseline gap-x-2 gap-y-0.5 rounded-xl sm:rounded-2xl border-[3px] border-amber-400 bg-gradient-to-r from-amber-100 via-yellow-100 to-amber-50 px-2.5 py-2 sm:px-4 sm:py-3 shadow-md max-w-full']}>
                    <span class="shrink-0 rounded-md bg-amber-500 px-1.5 py-0.5 text-[10px] sm:text-sm font-black text-white">特典</span>
                    <span class="font-black text-gray-900 text-sm sm:text-lg md:text-xl whitespace-nowrap">通常</span>
                    <span class="font-black text-red-600 text-lg sm:text-2xl md:text-3xl whitespace-nowrap">2,000円</span>
                    <span class="font-black text-gray-900 text-sm sm:text-lg md:text-xl">の</span>
                    <span class="font-black text-red-600 text-base sm:text-2xl md:text-3xl">抗菌コート</span>
                    <span class="font-black text-blue-900 text-sm sm:text-xl md:text-2xl whitespace-nowrap">→ 今月末まで無料</span>
                </div>
            )}

            {/* 4. メインキャッチ（2行）— 全LP共通 */}
            <h1 class:list={[
                gap,
                'font-black text-blue-900 leading-[1.05] tracking-tight',
                adHero
                    ? 'text-[clamp(1.5rem,6.8vw,3.4rem)] md:text-8xl lg:text-9xl'
                    : 'text-[clamp(1.85rem,9vw,7rem)] md:text-8xl lg:text-9xl',
            ]}>
                <span class="block">早急に解決！</span>
                <span class="block">特急便</span>
            </h1>

            {/* 5. メイン訴求（赤帯）— 全LP共通 */}
            <div class:list={[gap, 'bg-red-600 text-white py-2 max-md:py-2 sm:py-2.5 md:py-3 px-3 sm:px-5 rounded-xl sm:rounded-2xl shadow-lg inline-block max-w-full']}>
                <p class="text-[clamp(1.35rem,5.5vw,1.75rem)] sm:text-xl md:text-3xl font-black tracking-wide leading-tight max-md:leading-snug">
                    {adHero ? (
                        <>
                            <span class="whitespace-nowrap">{adHero.highlightLine1}</span><wbr /><span class="whitespace-nowrap">{adHero.highlightLine2}</span>
                        </>
                    ) : (
                        <>
                            <span class="whitespace-nowrap">おうと（嘔吐）、</span><wbr /><span class="whitespace-nowrap">におい、</span><wbr /><span class="whitespace-nowrap">灯油こぼし</span>
                        </>
                    )}
                </p>
            </div>

            {/* 6. キャンペーン（黄色）— 全LP共通 */}
            <div class:list={[gap, 'bg-yellow-100 border-[3px] sm:border-4 border-yellow-400 p-2.5 sm:p-4 md:p-8 rounded-2xl sm:rounded-3xl shadow-xl inline-block w-full max-w-xl']}>
                <p class="text-sm sm:text-base md:text-2xl font-bold text-gray-800 mb-0.5 leading-tight">
                    <span class="whitespace-nowrap">今月末まで、</span><wbr /><span class="whitespace-nowrap">通常2,000円の</span>
                </p>
                <p class="text-xl sm:text-4xl md:text-6xl font-black text-red-600 animate-pulse leading-[1.1]">
                    <span class="whitespace-nowrap">抗菌コート</span><wbr /> <span class="whitespace-nowrap">無料！</span>
                </p>
            </div>

            {/* 7. サブキャッチ — 全LP共通 */}
            <p class:list={[gap, 'text-base sm:text-lg md:text-3xl font-bold text-gray-700 leading-snug']}>
                {adHero ? (
                    <span class="whitespace-nowrap">{adHero.subcatch}</span>
                ) : (
                    <>
                        <span class="whitespace-nowrap">{displayName}の</span><wbr /><span class="whitespace-nowrap">車内クリーニング・</span><wbr /><span class="whitespace-nowrap">消臭洗浄</span>
                    </>
                )}
            </p>

            {/* 8. 緊急対応テキスト — 全LP共通 */}
            <p class:list={[gap, 'text-sm sm:text-base md:text-2xl font-black text-gray-800 leading-snug bg-white/80 inline-block px-2.5 sm:px-4 py-1.5 sm:py-2 rounded-lg max-w-full']}>
                {adHero ? (
                    <span>{adHero.footerText}</span>
                ) : (
                    <>
                        <span class="whitespace-nowrap">嘔吐・灯油こぼしの</span><wbr /><span class="whitespace-nowrap">緊急トラブル</span> <span class="text-red-600 underline decoration-4 whitespace-nowrap">すぐ対応</span><wbr /> <span class="whitespace-nowrap">駆けつけます</span>
                    </>
                )}
            </p>

            {/* 9. ディーラー比較 — 全LP共通 */}
            <div class="bg-white/55 max-md:border max-md:border-red-400/50 max-md:shadow-md border-4 border-red-500 p-2 max-md:py-1.5 sm:p-4 md:p-8 rounded-xl sm:rounded-2xl max-md:rounded-xl shadow-2xl max-md:shadow-none mb-2 sm:mb-6 md:mb-8 w-full max-w-xl md:bg-white backdrop-blur-[2px] max-md:backdrop-blur-sm">
                <p class="text-sm max-md:text-gray-700/90 sm:text-lg md:text-2xl font-bold text-gray-800 mb-0.5 max-md:mb-0 leading-tight">
                    <span class="whitespace-nowrap">ディーラーで</span><wbr /><span class="whitespace-nowrap">5日待てますか？</span>
                </p>
                <p class="text-sm max-md:font-semibold max-md:text-red-600/35 sm:text-4xl md:text-7xl font-black text-red-600 leading-none">
                    絶対ムリ！
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    h1 {
        text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
    }
</style>
