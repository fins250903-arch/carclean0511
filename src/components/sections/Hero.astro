---
import { STORE_NAME } from '../../lib/site';
import { IMG513 } from '../../lib/assets513';

interface AdHeroOverrides {
  subtitle: string;
  highlightLine1: string;
  highlightLine2: string;
  subcatch: string;
  fvImage: string;
  footerText: string;
}

interface Props {
  regionName: string;
  displayName: string;
  niche?: 'car' | 'truck';
  adHero?: AdHeroOverrides;
}

const { regionName, displayName, niche = 'car', adHero } = Astro.props;
const isTruck = niche === 'truck';

const subtitle = adHero?.subtitle ?? (isTruck 
    ? `${displayName}トラックキャビン清掃専門店/キャビン洗浄`
    : `${displayName}車内クリーニング専門店/シート洗浄`);

const fvImage = adHero?.fvImage ?? (isTruck ? "/images/truck-fv.png" : IMG513.fvCar);
---

<section class="relative w-full min-h-screen md:h-[95vh] flex items-center bg-white overflow-hidden">
    <div class="absolute inset-0 w-full h-full z-0">
        <img
            src={fvImage}
            alt={`${displayName}対応 ${STORE_NAME}`}
            class="w-full h-full object-cover object-[center_bottom] md:object-right opacity-90"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent z-10"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 md:px-16 z-20 relative pt-6 md:pt-0">
        <div class="max-w-3xl">
            {/* 0. 最上部テキスト */}
            <div class="mb-3 flex flex-wrap gap-2">
                <span class="inline-flex bg-red-600 text-white text-xs sm:text-sm md:text-base font-bold px-3 sm:px-4 py-1.5 rounded-full">
                    ３６５日２４時間受付中
                </span>
                <span class="inline-flex bg-blue-900 text-white text-xs sm:text-sm md:text-base font-bold px-3 sm:px-4 py-1.5 rounded-full">
                    "出張"車内クリーニング業者
                </span>
            </div>

            {/* 1. 小見出し */}
            <p class="text-sm sm:text-base md:text-2xl font-bold text-gray-800 mb-2 leading-snug">
                {subtitle}
            </p>

            {/* 2. メインキャッチコピー */}
            <h1 class="text-[clamp(2rem,10vw,7rem)] md:text-8xl lg:text-9xl font-black text-blue-900 leading-[1.1] mb-2 tracking-tight">
                早急に解決！特急便
            </h1>

            {/* 2.5 メイン訴求 */}
            <div class="bg-red-600 text-white py-2.5 sm:py-3 px-4 sm:px-5 rounded-2xl shadow-lg mb-4 inline-block max-w-full">
                <p class="text-lg sm:text-xl md:text-3xl font-black tracking-wide leading-tight">
                    {adHero ? (
                        <>
                            <span class="whitespace-nowrap">{adHero.highlightLine1}</span><wbr /><span class="whitespace-nowrap">{adHero.highlightLine2}</span>
                        </>
                    ) : (
                        <>
                            <span class="whitespace-nowrap">おうと（嘔吐）、</span><wbr /><span class="whitespace-nowrap">におい、</span><wbr /><span class="whitespace-nowrap">灯油こぼし</span>
                        </>
                    )}
                </p>
            </div>

            {/* 3. サブキャッチ */}
            <p class="text-base sm:text-lg md:text-3xl font-bold text-gray-700 mb-5 sm:mb-6 leading-snug">
                {adHero ? (
                    <span class="whitespace-nowrap">{adHero.subcatch}</span>
                ) : (
                    <>
                        <span class="whitespace-nowrap">{displayName}の</span><wbr /><span class="whitespace-nowrap">車内クリーニング・</span><wbr /><span class="whitespace-nowrap">消臭洗浄</span>
                    </>
                )}
            </p>
            
            {/* 4. キャンペーンボックス（黄色） */}
            <div class="bg-yellow-100 border-4 border-yellow-400 p-4 md:p-8 rounded-3xl shadow-xl mb-4 inline-block w-full max-w-xl">
                <p class="text-base sm:text-lg md:text-2xl font-bold text-gray-800 mb-1 leading-tight">
                    <span class="whitespace-nowrap">今なら、</span><wbr /><span class="whitespace-nowrap">通常2,000円の</span>
                </p>
                <p class="text-3xl sm:text-4xl md:text-6xl font-black text-red-600 animate-pulse leading-tight">
                    <span class="whitespace-nowrap">抗菌コート</span><wbr /> <span class="whitespace-nowrap">無料！</span>
                </p>
            </div>

            {/* 5. 緊急トラブルボックス（白背景・赤枠） */}
            <div class="bg-white border-4 border-red-500 p-4 md:p-8 rounded-3xl shadow-2xl mb-6 sm:mb-8 w-full max-w-xl">
                <p class="text-base sm:text-lg md:text-2xl font-bold text-gray-800 mb-1 leading-tight">
                    <span class="whitespace-nowrap">ディーラーで</span><wbr /><span class="whitespace-nowrap">5日待てますか？</span>
                </p>
                <p class="text-3xl sm:text-4xl md:text-7xl font-black text-red-600 leading-none">
                    絶対ムリ！
                </p>
            </div>

            {/* 6. CTAボタン */}
            <div class="flex flex-col gap-3 sm:gap-4 mb-5">
                <a
                    href="https://lin.ee/Xs8Orp2"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full bg-[#06C755] hover:bg-[#05a346] text-white font-black py-4 sm:py-5 px-6 sm:px-10 rounded-2xl sm:rounded-full shadow-2xl text-lg sm:text-xl md:text-3xl transition-transform hover:scale-105 text-center flex items-center justify-center gap-2 sm:gap-3"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-message-circle shrink-0"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                    <span class="whitespace-nowrap">LINEで見積もり</span><span class="text-xs sm:text-sm font-bold opacity-90">（写真で即見積）</span>
                </a>
                <a
                    href="tel:07084280866"
                    class="w-full bg-red-600 hover:bg-red-700 text-white font-black py-4 sm:py-5 px-6 sm:px-10 rounded-2xl sm:rounded-full shadow-2xl text-lg sm:text-xl md:text-3xl transition-transform hover:scale-105 text-center flex items-center justify-center gap-2 sm:gap-3 animate-pulse ring-4 ring-red-300"
                >
                    <span class="shrink-0">📞</span><span class="whitespace-nowrap">今すぐ電話 070-8428-0866</span>
                </a>
            </div>

            {/* 7. 補足テキスト */}
            <p class="text-base sm:text-lg md:text-2xl font-black text-gray-800 leading-snug bg-white/70 inline-block px-3 sm:px-4 py-2 rounded-lg max-w-full">
                {adHero ? (
                    <span>{adHero.footerText}</span>
                ) : (
                    <>
                        <span class="whitespace-nowrap">嘔吐・灯油こぼしの</span><wbr /><span class="whitespace-nowrap">緊急トラブル</span> <span class="text-red-600 underline decoration-4 whitespace-nowrap">すぐ対応</span><wbr /> <span class="whitespace-nowrap">駆けつけます</span>
                    </>
                )}
            </p>
        </div>
    </div>
</section>

<style>
    h1 {
        text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
    }
</style>
