---
import type { ServiceNiche } from '../../lib/niche';
import { regionPath } from '../../lib/niche';

interface Props {
  regionName: string;
  displayName: string;
  niche?: ServiceNiche | 'coating';
  path: string;
  regionBasePath?: string;
  /** 例: osaka — サブエリアページから親大阪へリンク */
  regionBaseId?: string;
}

const { displayName, niche = 'car', path, regionBasePath, regionBaseId } = Astro.props;

if (niche === 'coating') return null;

const baseId =
  regionBaseId ??
  (path.match(/\/regions\/([^/]+)/)?.[1]?.replace(/-truck$|-bus$/, '') ?? 'osaka');

const carPath = regionPath(baseId, 'car');
const truckPath = regionPath(baseId, 'truck');
const busPath = regionPath(baseId, 'bus');

const links = [
  {
    niche: 'car' as const,
    href: carPath,
    badge: 'PASSENGER',
    title: '乗用車・普通車',
    desc: '嘔吐・灯油・ペット臭。出張車内清掃・シート洗浄。',
    image: '/images/fv_change_v2.png',
    hidden: niche === 'car',
  },
  {
    niche: 'truck' as const,
    href: truckPath,
    badge: 'TRUCK',
    title: 'トラック・キャビン',
    desc: '10t・中型トラックのキャビン洗浄・ヤニ臭除去。',
    image: '/images/truck-fv.png',
    hidden: niche === 'truck',
  },
  {
    niche: 'bus' as const,
    href: busPath,
    badge: 'BUS',
    title: 'バス・マイクロバス',
    desc: '観光バス・送迎バスの嘔吐・尿漏れ区画洗浄。',
    image: '/images/kw/bus-fv.png',
    hidden: niche === 'bus',
  },
].filter((l) => !l.hidden);
---

<section class="py-12 bg-gray-50 border-t border-gray-200">
  <div class="container mx-auto px-6 md:px-8">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8 text-gray-900">
        {displayName}の出張車内清掃（他車種も対応）
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            class="group flex flex-col bg-white rounded-2xl shadow-lg overflow-hidden border-2 border-primary/10 hover:border-primary transition-all"
          >
            <div class="h-40 overflow-hidden relative">
              <img
                src={link.image}
                alt={link.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <span class="absolute top-3 left-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">
                {link.badge}
              </span>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-bold text-gray-900 mb-2">
                {displayName}の{link.title}専門ページへ
              </h3>
              <p class="text-gray-600 text-sm mb-3">{link.desc}</p>
              <span class="text-primary font-bold text-sm">詳細を見る →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
