{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "coverImage": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shortSlug": {
      "type": "string"
    },
    "seo": {
      "type": "object",
      "properties": {
        "meta_title": {
          "type": "string"
        },
        "meta_description": {
          "type": "string"
        },
        "keywords": {
          "type": "string"
        },
        "noindex": {
          "default": false,
          "type": "boolean"
        }
      }
    },
    "ogp": {
      "type": "object",
      "properties": {
        "og_image": {
          "type": "string"
        },
        "og_type": {
          "default": "article",
          "type": "string",
          "enum": [
            "article",
            "website"
          ]
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}